# Server Configuration
PORT=3001

# LLM Providers Configuration (At least one is required)
# Gemini API Key (Recommended, free tier available at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional fallback, get it from https://platform.openai.com/)
OPENAI_API_KEY=your_openai_api_key_here

# Default LLM Provider to use ('gemini' or 'openai')
DEFAULT_PROVIDER=gemini

# Specific Gemini Model Identifier (Optional override)
# If 'gemini-1.5-flash' returns a 404 error, you can configure it here (e.g., gemini-1.5-flash-latest, gemini-1.5-pro, or gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-1.5-flash
